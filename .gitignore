# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
pip-wheel-metadata/
*.egg

# Virtual environments
venv/
.env/
.venv/
env/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Mypy/cache
.mypy_cache/

# Editor directories and files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Swap files
*.swp
*.swo

# Temporary files
tmp/
temp/

# Logs
*.log


# Other
*.bak
*.orig

# Ignore Python bytecode created by setuptools
.eggs/

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec
